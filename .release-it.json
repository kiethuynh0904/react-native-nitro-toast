{
  "$schema": "https://unpkg.com/release-it@19/schema/release-it.json",
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "requireCleanWorkingDir": true
  },
  "hooks":{
    "before:init": ["git pull", "bun run lint:ci"],
    "after:bump": ["bunx auto-changelog -p"]
  },
  "github": {
    "release": true
  },
  "npm": {
    "publish": false
  }
}
